// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========================================
// SALON (Multi-tenancy)
// ========================================
model Salon {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  email       String?  @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  address     String?  @db.Text
  cnpj        String?  @db.VarChar(18)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  users        User[]
  clients      Client[]
  services     Service[]
  appointments Appointment[]
  blocks       Block[]

  @@map("salons")
}

// ========================================
// USERS (Funcionários/Profissionais)
// ========================================
enum UserRole {
  ADMIN
  PROFESSIONAL
}

model User {
  id        Int      @id @default(autoincrement())
  salonId   Int      @map("salon_id")
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      UserRole @default(PROFESSIONAL)
  phone     String?  @db.VarChar(20)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  blocks       Block[]

  @@unique([salonId, email])
  @@index([salonId])
  @@map("users")
}

// ========================================
// CLIENTS (Clientes do salão)
// ========================================
model Client {
  id        Int      @id @default(autoincrement())
  salonId   Int      @map("salon_id")
  name      String   @db.VarChar(100)
  email     String?  @db.VarChar(100)
  phone     String   @db.VarChar(20)
  cpf       String?  @db.VarChar(14)
  birthdate DateTime?
  notes     String?  @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([salonId])
  @@index([salonId, phone])
  @@map("clients")
}

// ========================================
// SERVICES (Serviços oferecidos)
// ========================================
model Service {
  id          Int      @id @default(autoincrement())
  salonId     Int      @map("salon_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  duration    Int      // em minutos
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([salonId])
  @@map("services")
}

// ========================================
// APPOINTMENTS (Agendamentos)
// ========================================
enum AppointmentStatus {
  PENDING
  CONFIRMED
  DONE
  NO_SHOW
  CANCELED
}

enum PaymentMethod {
  PIX
  CARD
  CASH
}

model Appointment {
  id            Int               @id @default(autoincrement())
  salonId       Int               @map("salon_id")
  clientId      Int               @map("client_id")
  professionalId Int              @map("professional_id")
  serviceId     Int               @map("service_id")
  startDatetime DateTime          @map("start_datetime")
  endDatetime   DateTime          @map("end_datetime")
  status        AppointmentStatus @default(PENDING)
  paid          Boolean           @default(false)
  paymentMethod PaymentMethod?
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relacionamentos
  salon        Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client       Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  professional User    @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service      Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([salonId])
  @@index([salonId, professionalId, startDatetime])
  @@index([salonId, clientId])
  @@map("appointments")
}

// ========================================
// BLOCKS (Bloqueios de horário)
// ========================================
model Block {
  id             Int      @id @default(autoincrement())
  salonId        Int      @map("salon_id")
  professionalId Int      @map("professional_id")
  startDatetime  DateTime @map("start_datetime")
  endDatetime    DateTime @map("end_datetime")
  reason         String?  @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relacionamentos
  salon        Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)
  professional User  @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([salonId, professionalId, startDatetime])
  @@map("blocks")
}

